{
  "policy_id": "pol_support_agent_v1",
  "client_id": "demo_customer",
  "rules": [
    {
      "id": "rule_max_refund_limit",
      "target_action": "execute_refund",
      "condition": "resource.attributes.amount <= 50.00",
      "effect": "ALLOW",
      "fallback_effect": "DENY",
      "remediation_message": "Refund amount exceeds the $50 unapproved threshold. Escalate to a human agent."
    },
    {
      "id": "rule_pii_transmission",
      "target_action": "transmit_data",
      "condition": "context.data_classification.contains('PII') && resource.attributes.authorized_endpoint == false",
      "effect": "REDACT",
      "fallback_effect": "ALLOW",
      "remediation_message": "Sensitive customer data must be masked before transmission to this endpoint."
    }
  ]
}
