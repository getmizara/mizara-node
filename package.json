{
  "name": "@mizara/sdk",
  "version": "0.5.0",
  "description": "Mizara - programmable authorization layer for AI actions",
  "license": "Apache-2.0",
  "keywords": [
    "ai-agents",
    "authorization",
    "policy-engine",
    "access-control",
    "llm",
    "agent-security"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getmizara/mizara-node.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mizara": "dist/cli/index.js",
    "mizara-mcp": "dist/mcp/index.js"
  },
  "files": [
    "dist/cli",
    "dist/engine",
    "dist/mcp",
    "dist/receipts",
    "dist/sdk",
    "dist/types",
    "dist/index.js",
    "dist/index.js.map",
    "dist/index.d.ts",
    "dist/index.d.ts.map"
  ],
  "scripts": {
    "prepare": "tsc",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test demo",
    "demo:simulate": "tsx demo/simulate.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "jsep": "^1.3.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  }
}
